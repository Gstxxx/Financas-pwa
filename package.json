{
  "name": "financas",
  "version": "1.2.1",
  "private": true,
  "description": "Dashboard financeiro pessoal — desktop app",
  "author": {
    "name": "Financas"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build:web": "next build",
    "lint": "next lint",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:icon": "node scripts/build-icon.mjs",
    "electron:dev": "concurrently -k -n NEXT,ELEC -c blue,magenta \"next dev\" \"wait-on tcp:3000 && npm run build:electron && cross-env ELECTRON_DEV=1 electron dist-electron/main.js\"",
    "build": "npm run build:icon && npm run build:electron && npm run build:web",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "release": "node scripts/release.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "geist": "^1.3.1",
    "jspdf": "^4.2.1",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.financas.desktop",
    "productName": "Financas",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Financas",
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Gstxxx",
        "repo": "Financas-pwa",
        "releaseType": "release"
      }
    ]
  }
}
